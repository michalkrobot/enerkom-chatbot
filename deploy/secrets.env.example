# Zkopíruj jako deploy/secrets.env a vyplň. NEVERZUJ (je v .gitignore / .dockerignore).
# Hodnoty čte deploy/setup.ps1.

# Heslo pro dedikovanou DB roli chatbot_app (stejné použij v deploy/db-setup.sql)
POSTGRES_APP_PASSWORD=zmen-silne-heslo-pro-roli-chatbot_app

# Azure OpenAI:
#   Endpoint i klíč si setup.ps1 vytvoří a načte SÁM z nově vytvořeného resource
#   (chatbot-openai). Nic sem doplňovat NETŘEBA.
#
# Pokud chceš použít UŽ EXISTUJÍCÍ Azure OpenAI resource, odkomentuj a vyplň
# (setup.ps1 pak přeskočí tvorbu resource):
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_KEY=<klic>
